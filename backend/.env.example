# ========================
# DATABASE
# ========================
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/ecommerce?retryWrites=true&w=majority
DB_NAME=ecommerce

# ========================
# JWT
# ========================
JWT_SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================
# VIETQR (Miễn phí, ưu tiên)
# Lấy bank_id tại: https://api.vietqr.io/v2/banks
# ========================
VIETQR_BANK_ID=MB
VIETQR_ACCOUNT_NO=1234567890
VIETQR_ACCOUNT_NAME=NGUYEN VAN A
VIETQR_TEMPLATE=compact2
# VietQR Pro (tuỳ chọn, để trống nếu dùng free tier)
VIETQR_CLIENT_ID=
VIETQR_API_KEY=

# ========================
# MOMO (Tuỳ chọn - cần tài khoản merchant)
# Sandbox: https://test-payment.momo.vn
# ========================
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:3000/orders
MOMO_IPN_URL=http://localhost:8000/api/webhook/momo

# ========================
# ZALOPAY (Tuỳ chọn - cần tài khoản merchant)
# Sandbox: https://sb-openapi.zalopay.vn
# ========================
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_CALLBACK_URL=http://localhost:8000/api/webhook/zalopay

# ========================
# SERVER
# ========================
BACKEND_URL=http://localhost:8000
# Khi test webhook local, dùng ngrok rồi điền URL public vào đây:
# BACKEND_URL=https://xxxx.ngrok-free.app

FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# ========================
# WEBHOOK SECURITY
# ========================
# Chuỗi bí mật để verify chữ ký webhook (tự tạo, đủ dài)
WEBHOOK_SECRET=change-this-webhook-secret-32-chars-min

# ========================
# CLOUDINARY (Lưu ảnh sản phẩm - tuỳ chọn)
# ========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
